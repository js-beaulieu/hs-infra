# Current URL shape
# Copy to tests/flows/current.env and replace placeholders.

WEB_ORIGIN=https://tasks.home-stack.localhost
API_BASE=https://api.home-stack.localhost/tasks
MCP_RESOURCE=https://api.home-stack.localhost/tasks/mcp
MCP_METADATA=https://api.home-stack.localhost/tasks/.well-known/oauth-protected-resource/mcp
OAUTH2_BASE=https://api.home-stack.localhost/oauth2

KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin-password

TEST_USER_PREFIX=flowtest
TEST_USER_PASSWORD=ChangeMe123
TEST_DENIED_USER_PASSWORD=ChangeMe123

# MCP tokens are auto-generated from Keycloak during global setup when
# KEYCLOAK_ADMIN_PASSWORD is set. Set them here only to override.
MCP_TOKEN_VALID=
MCP_TOKEN_WRONG_AUD=
MCP_TOKEN_EXPIRED=
MCP_TOKEN_MISSING_GROUP=
