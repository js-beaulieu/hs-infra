# Migrated URL shape (post-migration)
# Copy to tests/flows/migrated.env and replace placeholders.

WEB_ORIGIN=https://tasks.home-stack.localhost
API_BASE=https://api.tasks.home-stack.localhost
MCP_RESOURCE=https://api.tasks.home-stack.localhost/mcp
MCP_METADATA=https://api.tasks.home-stack.localhost/.well-known/oauth-protected-resource/mcp
OAUTH2_BASE=https://api.tasks.home-stack.localhost/oauth2

KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin-password

TEST_USER_USERNAME=testuser
TEST_USER_PASSWORD=ChangeMe123
TEST_DENIED_USER_USERNAME=denieduser
TEST_DENIED_USER_PASSWORD=ChangeMe123

# MCP tokens are optional; tests that need them are skipped when absent.
MCP_TOKEN_VALID=
MCP_TOKEN_WRONG_AUD=
MCP_TOKEN_EXPIRED=
MCP_TOKEN_MISSING_GROUP=
