# Starts an isolated Docker Compose project through Testcontainers.
# No real stack or checked-in flow env file is required.

FLOW_TEST_USE_TESTCONTAINERS=1
# Set to 1 while debugging to keep the disposable Compose project after tests.
FLOW_TEST_KEEP_TESTCONTAINERS=0

# Optional overrides. Defaults are shown here.
FLOW_TEST_DOMAIN=home-stack.localhost
TEST_USER_PREFIX=flowtest
TEST_USER_PASSWORD=ChangeMe123
TEST_DENIED_USER_PASSWORD=ChangeMe123
