#!/bin/sh
set -eu

{% if home_stack_source_mode == "git" %}
release_version="$(/usr/bin/tr -d '\r\n' < {{ home_stack_release_file | quote }})"
case "$release_version" in
  ""|-*|*..*|*[!A-Za-z0-9._/-]*)
    echo "Invalid home-stack release version: $release_version" >&2
    exit 1
    ;;
esac

if [ ! -d {{ home_stack_app_dir | quote }} ]; then
  /usr/bin/git clone {{ home_stack_git_repo | quote }} {{ home_stack_app_dir | quote }}
fi

cd {{ home_stack_app_dir | quote }}
/usr/bin/git fetch --prune origin '+refs/heads/*:refs/remotes/origin/*' '+refs/tags/*:refs/tags/*'
/usr/bin/git checkout --force --detach "$release_version"
/usr/bin/git clean -fdx
{% elif home_stack_source_mode == "local_copy" or home_stack_source_mode == "mounted" %}
cd {{ home_stack_app_dir | quote }}
{% endif %}

set -a
. {{ home_stack_env_file | quote }}
set +a

/usr/bin/docker compose {% for f in home_stack_compose_files %}-f {{ f }} {% endfor %}config --quiet
/usr/bin/docker compose {% for f in home_stack_compose_files %}-f {{ f }} {% endfor %}pull
/usr/bin/docker compose {% for f in home_stack_compose_files %}-f {{ f }} {% endfor %}down --remove-orphans
/usr/bin/docker compose {% for f in home_stack_compose_files %}-f {{ f }} {% endfor %}up -d --build
