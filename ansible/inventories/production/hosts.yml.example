---
# ansible_ssh_private_key_file cannot be templated from group_vars.
# Set the literal path here. This file is gitignored.
# For CI, the deploy workflow writes the key to ~/.ssh/home-stack-production.
home_stack:
  hosts:
    production-vps:
      ansible_host: vps.example.invalid
      ansible_user: debian
      ansible_port: 22
      ansible_ssh_private_key_file: ~/.ssh/home-stack-production
