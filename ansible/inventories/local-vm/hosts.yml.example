---
# SSH credentials are intentionally not configured here. Use normal
# Ansible/OpenSSH mechanisms: ssh-agent, ~/.ssh/config, --private-key,
# or ANSIBLE_PRIVATE_KEY_FILE.
home_stack:
  hosts:
    local-debian13-vm:
      ansible_host: 127.0.0.1
      ansible_port: 2222
      ansible_ssh_common_args: >-
        -o StrictHostKeyChecking=no
        -o UserKnownHostsFile=/dev/null
