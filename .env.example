# Copy to .env and replace all placeholder secrets before running the stack.

# Local default: auth.home-stack.localhost, api.home-stack.localhost, and tasks.home-stack.localhost resolve to loopback without /etc/hosts.
# Production: set this to your real domain, for example example.com.
DOMAIN=home-stack.localhost
ACME_EMAIL=admin@home-stack.localhost

# Optional full public origins. Leave unset for the standard no-port hostnames.
# Flow tests that start an isolated Testcontainers stack set these automatically.
# PUBLIC_AUTH_ORIGIN=https://auth.home-stack.localhost
# PUBLIC_WEB_ORIGIN=https://tasks.home-stack.localhost
# PUBLIC_OAUTH2_ORIGIN=https://api.home-stack.localhost
# PUBLIC_API_ORIGIN=https://api.home-stack.localhost/tasks
# MCP_RESOURCE_URI=https://api.home-stack.localhost/tasks/mcp
# MCP/DCR access tokens intentionally default to one year to work around
# current MCP client refresh/re-auth bugs. Browser/API oauth2-proxy tokens
# stay short and do not inherit this lifetime.
MCP_ACCESS_TOKEN_LIFESPAN_SECONDS=31536000
OAUTH2_PROXY_ACCESS_TOKEN_LIFESPAN_SECONDS=300

# Local HTTPS with mkcert:
#   mkcert -install
#   mkcert -cert-file certs/local.pem -key-file certs/local-key.pem auth.home-stack.localhost api.home-stack.localhost tasks.home-stack.localhost
#   cp "$(mkcert -CAROOT)/rootCA.pem" certs/rootCA.pem
# Production with public DNS/Let's Encrypt: set CADDY_TLS_DIRECTIVE to an empty value.
CADDY_TLS_DIRECTIVE="tls /certs/local.pem /certs/local-key.pem"
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Local Compose: do not trust Cloudflare headers. Caddy will derive client_ip from the direct peer.
# GitHub/Ansible production deploys fetch Cloudflare CIDRs automatically when WEB_EXPOSURE=cloudflare.
CADDY_TRUSTED_PROXIES="127.0.0.1/32 ::1/128"

# Local: allow admin only from local/private peers.
# Production behind Cloudflare: remote ranges must be Cloudflare CIDRs, client ranges must be your admin public CIDRs.
KEYCLOAK_ADMIN_REMOTE_IP_RANGES="private_ranges"
KEYCLOAK_ADMIN_CLIENT_IP_RANGES="private_ranges"

KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin-password
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me-keycloak-db-password

OAUTH2_PROXY_CLIENT_SECRET=change-me-oauth2-proxy-client-secret
OAUTH2_PROXY_COOKIE_SECRET=change-me-32-byte-base64-url-secret
OAUTH2_PROXY_PROVIDER_CA_FILES=/certs/rootCA.pem
# Defaults to .${DOMAIN} so browser SSO can span app subdomains.
# OAUTH2_PROXY_WHITELIST_DOMAINS=.home-stack.localhost

AGENTGATEWAY_SSL_CERT_FILE=/certs/rootCA.pem

# tasks-api database (shared Postgres instance, separate database)
TASKS_DB_NAME=tasks
TASKS_DB_USER=tasks
TASKS_DB_PASSWORD=change-me-tasks-db-password
