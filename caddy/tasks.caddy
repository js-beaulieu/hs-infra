api.{$DOMAIN} {
	import {$CADDY_TLS_INCLUDE}

	import strip_identity_headers

	@tasks_protected_resource_metadata path /tasks/.well-known/oauth-protected-resource/mcp
	@tasks_authorization_server_metadata path /tasks/.well-known/oauth-authorization-server/mcp /tasks/.well-known/oauth-authorization-server/mcp/client-registration
	@tasks_mcp_protected_resource_metadata path /tasks/mcp/.well-known/oauth-protected-resource
	@tasks_mcp_authorization_server_metadata path /tasks/mcp/.well-known/oauth-authorization-server /tasks/mcp/.well-known/oauth-authorization-server/client-registration

	@tasks_public_api_get {
		method GET
		path /tasks/health /tasks/openapi.json /tasks/openapi.yaml /tasks/openapi-3.0.json /tasks/openapi-3.0.yaml /tasks/docs
	}

	@tasks_public_schema_get {
		method GET
		path_regexp huma_schema ^/tasks/schemas/[^/]+$
	}

	@tasks_health_head {
		method HEAD
		path /tasks/health
	}

	@tasks_mcp path /tasks/mcp /tasks/mcp/*
	@tasks_api path /tasks /tasks/*

	@unsafe_cross_site `method('POST', 'PUT', 'PATCH', 'DELETE') && !({header.Origin} == "{$PUBLIC_WEB_ORIGIN}" || {header.Referer}.startsWith("{$PUBLIC_WEB_ORIGIN}/"))`
	@unsafe_bad_fetch_site `method('POST', 'PUT', 'PATCH', 'DELETE') && {header.Sec-Fetch-Site} == "cross-site"`

	@missing_tasks_group {
		not header_regexp tasks_group X-Auth-Request-Groups `(^|.*, *)/tasks-users(,.*|$)`
	}

	@cors_origin header Origin {$PUBLIC_WEB_ORIGIN}
	@preflight_allowed {
		method OPTIONS
		path /tasks /tasks/*
		header Origin {$PUBLIC_WEB_ORIGIN}
	}
	@preflight {
		method OPTIONS
		path /tasks /tasks/*
	}

	header @cors_origin {
		Access-Control-Allow-Origin "{$PUBLIC_WEB_ORIGIN}"
		Access-Control-Allow-Credentials "true"
		Vary "Origin"
	}

	route {
		handle /oauth2/* {
			reverse_proxy oauth2-proxy:4180 {
				import proxy_headers
				header_up -Authorization
			}
		}

		handle @tasks_protected_resource_metadata {
			uri strip_prefix /tasks
			reverse_proxy agentgateway:3000 {
				import proxy_headers
			}
		}

		handle @tasks_authorization_server_metadata {
			uri strip_prefix /tasks
			reverse_proxy agentgateway:3000 {
				import proxy_headers
			}
		}

		handle @tasks_mcp_protected_resource_metadata {
			rewrite * /.well-known/oauth-protected-resource/mcp
			reverse_proxy agentgateway:3000 {
				import proxy_headers
			}
		}

		handle /tasks/mcp/.well-known/oauth-authorization-server/client-registration {
			rewrite * /realms/home-stack/clients-registrations/openid-connect
			reverse_proxy keycloak:8080 {
				import proxy_headers
			}
		}

		handle /tasks/mcp/.well-known/oauth-authorization-server {
			rewrite * /realms/home-stack/.well-known/openid-configuration
			reverse_proxy keycloak:8080 {
				import proxy_headers
			}
		}

		handle @tasks_public_api_get {
			uri strip_prefix /tasks
			reverse_proxy tasks-api:8080 {
				import proxy_headers
				header_up -Authorization
			}
		}

		handle @tasks_public_schema_get {
			uri strip_prefix /tasks
			reverse_proxy tasks-api:8080 {
				import proxy_headers
				header_up -Authorization
			}
		}

		handle @tasks_health_head {
			uri strip_prefix /tasks
			reverse_proxy tasks-api:8080 {
				import proxy_headers
				header_up -Authorization
			}
		}

		handle @tasks_mcp {
			reverse_proxy agentgateway:3000 {
				import proxy_headers
			}
		}

		handle @preflight_allowed {
			import cors_tasks_origin
			respond "" 204
		}

		handle @preflight {
			respond 403
		}

		# App API catch-all. Future APIs should reserve their own /{app} prefix here.
		handle @tasks_api {
			route {
				respond @unsafe_cross_site 403
				respond @unsafe_bad_fetch_site 403

				import oauth2_auth_check
				import require_tasks_group
				request_header X-Auth-Name {header.X-Auth-Request-Preferred-Username}

				uri strip_prefix /tasks
				reverse_proxy tasks-api:8080 {
					import proxy_headers
					header_up -Authorization
					header_up X-User-ID {header.X-Auth-Request-User}
					header_up X-User-Name {header.X-Auth-Name}
					header_up X-User-Email {header.X-Auth-Request-Email}
				}
			}
		}

		handle {
			respond 404
		}
	}
}

tasks.{$DOMAIN} {
	import {$CADDY_TLS_INCLUDE}

	import strip_identity_headers

	@missing_tasks_group {
		not header_regexp tasks_group X-Auth-Request-Groups `(^|.*, *)/tasks-users(,.*|$)`
	}

	route {
		handle {
			import oauth2_browser_auth_check
			import require_tasks_group
			request_header X-Auth-Name {header.X-Auth-Request-Preferred-Username}

			reverse_proxy tasks-web:8080 {
				import proxy_headers
				header_up -Authorization
			}
		}
	}
}
